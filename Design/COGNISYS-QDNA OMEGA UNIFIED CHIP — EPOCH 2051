module qpu_array #(
    parameter int N_QUBITS   = QPU_QUBITS,
    parameter int N_GATES    = 8,
    parameter int TOPO_CODE  = 2
) (
    input  logic              clk_quantum,
    input  logic              clk_ctrl,
    input  logic              rst_n,

    input  logic [255:0]      quil_instruction,
    input  logic              quil_valid,
    output logic              quil_ready,

    output logic [N_QUBITS-1:0] measurement_result,
    output logic                measurement_valid,

    output logic [7:0]        coherence_map  [0:N_QUBITS/8-1],
    output logic              qpu_ready,

    input  logic              csm_freeze,
    output logic              decoherence_alert,

    output logic [63:0]       bell_pair_addr [0:31],
    output logic [31:0]       entanglement_valid
);

    qubit_state_t qubit_reg [0:N_QUBITS-1];

    logic [N_QUBITS-1:0]  x_syndrome;
    logic [N_QUBITS-1:0]  z_syndrome;
    logic                  syndrome_valid;

    logic [N_QUBITS-1:0]  correction_x, correction_z;
    logic                  correction_valid;

    typedef enum logic [3:0] {
        QPU_IDLE,
        QPU_DECODE_INST,
        QPU_APPLY_GATE,
        QPU_ERROR_CORRECT,
        QPU_MEASURE,
        QPU_ENTANGLE,
        QPU_FREEZE,
        QPU_REINIT
    } qpu_state_t;

    qpu_state_t state, next_state;
    logic [255:0] current_inst;
    logic [10:0]  target_qubit_a, target_qubit_b;
    logic [5:0]   gate_type;
    logic [31:0]  gate_cycle;

    always_comb begin
        gate_type     = current_inst[5:0];
        target_qubit_a= current_inst[16:6];
        target_qubit_b= current_inst[27:17];
    end

    always_ff @(posedge clk_quantum or negedge rst_n) begin
        if (!rst_n) begin
            state <= QPU_IDLE;
            qpu_ready <= 1'b0;
            decoherence_alert <= 1'b0;
            gate_cycle <= 32'b0;
            for (int i = 0; i < N_QUBITS; i++) begin
                qubit_reg[i].alpha_re <= 128'hFFFFFFFF_FFFFFFFF_FFFFFFFF_FFFFFFFF;
                qubit_reg[i].alpha_im <= 128'b0;
                qubit_reg[i].beta_re  <= 128'b0;
                qubit_reg[i].beta_im  <= 128'b0;
                qubit_reg[i].coherence<= 8'hFF;
                qubit_reg[i].qubit_id <= i[7:0];
            end
        end else if (csm_freeze) begin
            state <= QPU_FREEZE;
        end else begin
            state <= next_state;

            case (state)
                QPU_IDLE: begin
                    qpu_ready <= 1'b1;
                    if (quil_valid) begin
                        current_inst <= quil_instruction;
                        qpu_ready <= 1'b0;
                    end
                end

                QPU_DECODE_INST: begin
                    quil_ready <= 1'b1;
                end

                QPU_APPLY_GATE: begin
                    quil_ready <= 1'b0;
                    gate_cycle <= gate_cycle + 1;

                    case (gate_type)
                        6'b000001: begin
                            qubit_reg[target_qubit_a].alpha_re <=
                                (qubit_reg[target_qubit_a].alpha_re >> 1) +
                                (qubit_reg[target_qubit_a].beta_re  >> 1);
                            qubit_reg[target_qubit_a].beta_re  <=
                                (qubit_reg[target_qubit_a].alpha_re >> 1) -
                                (qubit_reg[target_qubit_a].beta_re  >> 1);
                        end
                        6'b000010: begin
                            logic [127:0] tmp_re, tmp_im;
                            tmp_re = qubit_reg[target_qubit_a].alpha_re;
                            tmp_im = qubit_reg[target_qubit_a].alpha_im;
                            qubit_reg[target_qubit_a].alpha_re <= qubit_reg[target_qubit_a].beta_re;
                            qubit_reg[target_qubit_a].alpha_im <= qubit_reg[target_qubit_a].beta_im;
                            qubit_reg[target_qubit_a].beta_re  <= tmp_re;
                            qubit_reg[target_qubit_a].beta_im  <= tmp_im;
                        end
                        6'b000011: begin
                            if (qubit_reg[target_qubit_a].beta_re > 128'h7FFFFFFF) begin
                                logic [127:0] tmp_re2, tmp_im2;
                                tmp_re2 = qubit_reg[target_qubit_b].alpha_re;
                                tmp_im2 = qubit_reg[target_qubit_b].alpha_im;
                                qubit_reg[target_qubit_b].alpha_re <= qubit_reg[target_qubit_b].beta_re;
                                qubit_reg[target_qubit_b].alpha_im <= qubit_reg[target_qubit_b].beta_im;
                                qubit_reg[target_qubit_b].beta_re  <= tmp_re2;
                                qubit_reg[target_qubit_b].beta_im  <= tmp_im2;
                            end
                        end
                        6'b000100: begin
                            qubit_reg[target_qubit_a].beta_re <=
                                qubit_reg[target_qubit_a].beta_re -
                                qubit_reg[target_qubit_a].beta_im;
                            qubit_reg[target_qubit_a].beta_im <=
                                qubit_reg[target_qubit_a].beta_re +
                                qubit_reg[target_qubit_a].beta_im;
                        end
                        default: ;
                    endcase
                end

                QPU_ERROR_CORRECT: begin
                    for (int i = 0; i < N_QUBITS - 4; i += 4) begin
                        x_syndrome[i] <= qubit_reg[i].alpha_re[0] ^
                                         qubit_reg[i+1].alpha_re[0];
                        z_syndrome[i] <= qubit_reg[i].beta_re[0] ^
                                         qubit_reg[i+2].beta_re[0];
                    end
                    syndrome_valid <= 1'b1;

                    if (|x_syndrome) begin
                        for (int j = 0; j < N_QUBITS; j++) begin
                            if (x_syndrome[j]) begin
                                qubit_reg[j].alpha_re <= qubit_reg[j].beta_re;
                                qubit_reg[j].beta_re  <= qubit_reg[j].alpha_re;
                            end
                        end
                    end

                    for (int k = 0; k < N_QUBITS; k++) begin
                        if (qubit_reg[k].coherence > 8'h01) begin
                            qubit_reg[k].coherence <= qubit_reg[k].coherence - 8'h01;
                        end else begin
                            decoherence_alert <= 1'b1;
                        end
                    end
                end

                QPU_MEASURE: begin
                    for (int m = 0; m < N_QUBITS; m++) begin
                        measurement_result[m] <=
                            (qubit_reg[m].alpha_re > qubit_reg[m].beta_re) ? 1'b0 : 1'b1;
                        qubit_reg[m].alpha_re <= 128'hFFFFFFFF_FFFFFFFF_FFFFFFFF_FFFFFFFF;
                        qubit_reg[m].beta_re  <= 128'b0;
                        qubit_reg[m].coherence<= 8'hFF;
                    end
                    measurement_valid <= 1'b1;
                end

                QPU_FREEZE: begin
                    if (!csm_freeze) state <= QPU_IDLE;
                end

                default: state <= QPU_IDLE;
            endcase
        end
    end

    always_comb begin
        next_state = state;
        case (state)
            QPU_IDLE        : if (quil_valid)          next_state = QPU_DECODE_INST;
            QPU_DECODE_INST : next_state = QPU_APPLY_GATE;
            QPU_APPLY_GATE  : if (gate_cycle > 32'd64) next_state = QPU_ERROR_CORRECT;
            QPU_ERROR_CORRECT: next_state = QPU_MEASURE;
            QPU_MEASURE     : next_state = QPU_IDLE;
            QPU_FREEZE      : if (!csm_freeze)         next_state = QPU_IDLE;
            default         : next_state = QPU_IDLE;
        endcase
    end

    genvar cg;
    generate
        for (cg = 0; cg < N_QUBITS/8; cg++) begin : coh_gen
            assign coherence_map[cg] = qubit_reg[cg*8].coherence;
        end
    endgenerate

    genvar bg;
    generate
        for (bg = 0; bg < 32; bg++) begin : bell_gen
            assign bell_pair_addr[bg]     = {52'b0, target_qubit_a, target_qubit_b};
            assign entanglement_valid[bg] = (state == QPU_ENTANGLE) && quil_valid;
        end
    endgenerate

endmodule


module photonic_noc #(
    parameter int N_ROUTERS  = 64,
    parameter int N_CHANNELS = PHOTON_CHANNELS,
    parameter int RING_SIZE  = 128
) (
    input  logic              clk_photon,
    input  logic              clk_ctrl,
    input  logic              rst_n,

    input  photon_packet_t    inject_port  [0:N_ROUTERS-1],
    input  logic              inject_valid [0:N_ROUTERS-1],
    output logic              inject_ready [0:N_ROUTERS-1],

    output photon_packet_t    eject_port   [0:N_ROUTERS-1],
    output logic              eject_valid  [0:N_ROUTERS-1],
    input  logic              eject_ready  [0:N_ROUTERS-1],

    input  logic [63:0]       quantum_src_addr,
    input  logic [63:0]       quantum_dst_addr,
    input  logic              quantum_req,
    output logic              quantum_ack,

    input  logic [15:0]       ring_temp_adc [0:N_ROUTERS-1],
    output logic [15:0]       ring_heater_dac [0:N_ROUTERS-1],

    output logic [31:0]       throughput_monitor,
    output logic              pnoc_healthy
);

    logic [2:0] route_x [0:N_ROUTERS-1];
    logic [2:0] route_y [0:N_ROUTERS-1];

    genvar ri;
    generate
        for (ri = 0; ri < N_ROUTERS; ri++) begin : route_tbl_gen
            assign route_x[ri] = ri[5:3];
            assign route_y[ri] = ri[2:0];
        end
    endgenerate

    logic [N_CHANNELS-1:0] vcsel_on    [0:N_ROUTERS-1];
    logic [7:0]            vcsel_power [0:N_ROUTERS-1][0:N_CHANNELS-1];

    logic [511:0] detected_data  [0:N_ROUTERS-1][0:N_CHANNELS-1];
    logic         detected_valid [0:N_ROUTERS-1][0:N_CHANNELS-1];

    always_ff @(posedge clk_ctrl or negedge rst_n) begin
        if (!rst_n) begin
            for (int r = 0; r < N_ROUTERS; r++) begin
                ring_heater_dac[r] <= 16'h8000;
                vcsel_on[r]        <= '0;
            end
        end else begin
            for (int r = 0; r < N_ROUTERS; r++) begin
                logic signed [15:0] temp_err;
                temp_err = 16'sh61A8 - ring_temp_adc[r];
                ring_heater_dac[r] <= ring_heater_dac[r] + (temp_err >>> 4);

                vcsel_on[r] <= inject_valid[r] ? '1 : '0;
            end
        end
    end

    logic [5:0] next_hop [0:N_ROUTERS-1];

    always_comb begin
        for (int s = 0; s < N_ROUTERS; s++) begin
            if (inject_valid[s]) begin
                automatic logic [2:0] dx, dy;
                automatic logic [2:0] sx, sy, dx_t, dy_t;
                sx = route_x[s];
                sy = route_y[s];
                dx_t = inject_port[s].dst_router[5:3];
                dy_t = inject_port[s].dst_router[2:0];

                if (sx < dx_t)
                    next_hop[s] = {sx + 3'b001, sy};
                else if (sx > dx_t)
                    next_hop[s] = {sx - 3'b001, sy};
                else if (sy < dy_t)
                    next_hop[s] = {sx, sy + 3'b001};
                else if (sy > dy_t)
                    next_hop[s] = {sx, sy - 3'b001};
                else
                    next_hop[s] = s[5:0];
            end else begin
                next_hop[s] = s[5:0];
            end
        end
    end

    always_ff @(posedge clk_ctrl or negedge rst_n) begin
        if (!rst_n) begin
            for (int r = 0; r < N_ROUTERS; r++) begin
                inject_ready[r] <= 1'b1;
                eject_valid[r]  <= 1'b0;
            end
        end else begin
            for (int r = 0; r < N_ROUTERS; r++) begin
                inject_ready[r] <= 1'b1;

                if (inject_valid[r] && next_hop[r] != r[5:0]) begin
                    eject_port[next_hop[r]]  <= inject_port[r];
                    eject_valid[next_hop[r]] <= 1'b1;
                end else if (inject_valid[r] && next_hop[r] == r[5:0]) begin
                    eject_port[r]  <= inject_port[r];
                    eject_valid[r] <= 1'b1;
                end else begin
                    eject_valid[r] <= 1'b0;
                end
            end
        end
    end

    logic [31:0] entangle_hop_count;
    logic [5:0]  entangle_src, entangle_dst;

    assign entangle_src = quantum_src_addr[5:0];
    assign entangle_dst = quantum_dst_addr[5:0];

    always_ff @(posedge clk_ctrl or negedge rst_n) begin
        if (!rst_n) begin
            quantum_ack <= 1'b0;
            entangle_hop_count <= 32'b0;
        end else if (quantum_req) begin
            entangle_hop_count <= entangle_hop_count + 1;
            if (entangle_hop_count > 32'd8) begin
                quantum_ack <= 1'b1;
                entangle_hop_count <= 32'b0;
            end
        end else begin
            quantum_ack <= 1'b0;
        end
    end

    logic [31:0] byte_counter;
    always_ff @(posedge clk_ctrl or negedge rst_n) begin
        if (!rst_n) byte_counter <= 32'b0;
        else begin
            for (int r = 0; r < N_ROUTERS; r++) begin
                if (inject_valid[r]) byte_counter <= byte_counter + 64;
            end
        end
    end
    assign throughput_monitor = byte_counter;
    assign pnoc_healthy = (|{vcsel_on}) || rst_n;

endmodule


