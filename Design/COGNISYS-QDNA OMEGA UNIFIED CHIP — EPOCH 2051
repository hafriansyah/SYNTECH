    ltssm_t ltssm; logic [31:0] tc;
    always_ff @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin ltssm<=LTSSM_DETECT; link_up<=1'b0; link_speed<=4'b0001; tc<=32'b0; cxl_mem_enable<=1'b0; end
